generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth Models required for Google OAuth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  events        Event[]       @relation("HostEvents")
  participants  Participant[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Ngumpul Models
model Event {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  desc             String?
  location_name    String?
  location_address String?
  lat              Float?
  lng              Float?
  place_id         String?
  host_id          String
  date_range       String[]  // Store as ISO strings or specific JSON
  time_range       String[]  // i.e., ["09:00", "21:00"]
  timezone         String    @default("Asia/Jakarta")
  deadline         DateTime?
  confirmed_slot   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  host             User      @relation("HostEvents", fields: [host_id], references: [id], onDelete: Cascade)
  participants     Participant[]
  availabilities   Availability[]
  participant_locations ParticipantLocation[]
}

model Participant {
  id         String   @id @default(cuid())
  event_id   String
  user_id    String?
  guest_name String?
  token      String?  @unique // For guest editing

  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  
  availabilities Availability[]
  locations      ParticipantLocation[]

  @@unique([event_id, user_id]) // A user can only join once per event
}

model Availability {
  id             String      @id @default(cuid())
  participant_id String
  event_id       String
  slot_datetime  String      // E.g., "2026-03-25-10:00"
  is_available   Boolean     @default(true)

  participant    Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  event          Event       @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([participant_id, slot_datetime])
}

model ParticipantLocation {
  id             String      @id @default(cuid())
  participant_id String
  event_id       String
  location_name  String
  lat            Float?
  lng            Float?

  participant    Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  event          Event       @relation(fields: [event_id], references: [id], onDelete: Cascade)
}
