# ─────────────────────────────────────────────────────────────────────────────
# NGUMPUL — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit .env to version control.
# ⚠️  Never expose SUPABASE_SERVICE_ROLE_KEY, AUTH_SECRET, or DB credentials
#     to frontend code (no NEXT_PUBLIC_ prefix on secret values).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres via PgBouncer) ────────────────────────────────
# Prisma uses this for pooled connections (transactions disabled).
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Direct connection for Prisma migrations (bypasses PgBouncer).
DIRECT_URL="postgres://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Supabase — Public (safe to expose to frontend) ────────────────────────────
# These are intentionally public — the anon key is scoped by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<your-publishable-key>"

# ── Supabase — Server Only (NEVER use NEXT_PUBLIC_ prefix below) ──────────────
# The service role key bypasses Row Level Security — keep it strictly server-side.
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
SUPABASE_JWT_SECRET="<your-supabase-jwt-secret>"
SUPABASE_SECRET_KEY="sb_secret_<your-secret-key>"

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="<generate-with-openssl-rand-base64-32>"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID="<your-google-client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"

# ── Google Maps (Server-Only) ─────────────────────────────────────────────────
# Used only in lib/maps.ts (server-side Distance Matrix API calls).
# Restrict this key to server IPs in Google Cloud Console.
GOOGLE_MAPS_API_KEY="<your-google-maps-server-key>"

# ── Firebase — Public (Client SDK) ───────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY="<your-api-key>"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="<your-auth-domain>"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="<your-project-id>"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="<your-storage-bucket>"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="<your-messaging-sender-id>"
NEXT_PUBLIC_FIREBASE_APP_ID="<your-app-id>"

# ── Firebase — Server Only (Admin SDK) ────────────────────────────────────────
# The full JSON of your service account key file.
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'

